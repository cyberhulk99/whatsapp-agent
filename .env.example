# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Your WhatsApp display name (used to detect mentions)
MY_NAME=Suman

# Your WhatsApp phone number with country code (e.g., 919876543210 for India)
MY_PHONE=919876543210

# How many hours back to look for messages when summarizing (default: 8)
SUMMARY_HOURS=8

# Comma-separated chat names to monitor (leave empty to monitor ALL chats)
# Example: "Team Alpha,Project Backend,DevOps"
WATCH_CHATS=
