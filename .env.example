# ── AI Provider ──────────────────────────────────────────────────
# Choose: "claude" or "openai"
AI_PROVIDER=openai

# OpenAI API key (used when AI_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (used when AI_PROVIDER=claude)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── WhatsApp ──────────────────────────────────────────────────────
# Your WhatsApp display name (used to detect when someone mentions you)
MY_NAME=YourName

# Your phone number with country code, no + or spaces
# India example: 919876543210
# US example: 14155550123
MY_PHONE=919876543210

# How many hours back to look for messages on startup (default: 8)
SUMMARY_HOURS=8

# Comma-separated chat names to monitor (leave empty to monitor ALL chats)
# Example: "Friends,Work Team,Project Alpha"
WATCH_CHATS=
